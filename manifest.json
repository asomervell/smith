{
  "manifest_version": 3,
  "name": "Markdown Reader Mode",
  "description": "Auto-render pages as markdown when a site supports Accept: text/markdown.",
  "version": "0.1.0",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["markdown.js", "content.js"],
      "run_at": "document_start"
    }
  ]
}
